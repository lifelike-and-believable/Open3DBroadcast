*.bak
*.zip
include
lib

# Exception: Allow pre-built WebRTC libraries for Unreal plugin
!plugins/unreal/Open3DStream/ThirdParty/webrtc/**
build_release
vsbuild

# Visual Studio 2015 user specific files
.vs/

# VS Code settings (do not commit local editor config)
.vscode/

# Compiled Object files
*.slo
*.lo
*.o
*.obj

# Precompiled Headers
*.gch
*.pch

# Compiled Dynamic libraries
*.so
*.dylib
*.dll

# Fortran module files
*.mod

# Compiled Static libraries
*.lai
*.la
*.a
*.lib

# Executables
*.exe
*.out
*.app
*.ipa

# These project files can be generated by the engine
*.xcodeproj
*.xcworkspace
*.sln
*.suo
*.opensdf
*.sdf
*.VC.db
*.VC.opendb

# Precompiled Assets
SourceArt/**/*.png
SourceArt/**/*.tga

# Binary Files
Binaries/*
Plugins/*/Binaries/*

# Builds (Both cases since not all OSes are case insensitive)
Build/*
build/

# Local quick build directories (do not commit)
build_quick/
thirdparty/build_quick/

# Whitelist PakBlacklist-<BuildConfiguration>.txt files
!Build/*/
Build/*/**
!Build/*/PakBlacklist*.txt
!Build/o3ds-core/CMakeLists.txt
!Build/o3ds-core/README.md

# Don't ignore icon files in Build
!Build/**/*.ico

# Built data for maps
*_BuiltData.uasset

# Configuration files generated by the Editor
Saved/*

# Compiled source files for the engine to use
Intermediate/*
Plugins/*/Intermediate/*

# Cache files for the editor to use
DerivedDataCache/*
*.pdb
/plugins/unreal/Open3DStream/Binaries
